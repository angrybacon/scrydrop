{
  "bin": {
    "scrydrop": "./dist/scrydrop.mjs"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "license": "MIT",
  "name": "@korumite/scrydrop",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angrybacon/scrydrop.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "lint": "pnpm run --aggregate-output '/^lint:[^:]+$/'",
    "lint:format": "prettier --check --log-level warn lib/ server/",
    "lint:prune": "knip",
    "lint:typings": "tsc",
    "start": "tsx ./server"
  },
  "dependencies": {
    "async-sema": "3.1.1",
    "plaiceholder": "3.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@korumite/ts": "1.5.0",
    "@types/node": "24.12.2",
    "commander": "14.0.3",
    "knip": "6.7.0",
    "prettier": "3.8.3",
    "tsdown": "0.21.10",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
